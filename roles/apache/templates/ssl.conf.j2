Listen 443 https

<VirtualHost *:443>

ServerName {{ server_name }}

DocumentRoot {{ document_root }}

SSLEngine on

SSLCertificateFile /etc/pki/tls/certs/server.crt
SSLCertificateKeyFile /etc/pki/tls/private/server.key

<Directory {{ document_root }}>
    AllowOverride All
    Require all granted
</Directory>

</VirtualHost>
